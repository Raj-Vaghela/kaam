<div class="relative rounded-lg mx-4 sm:mx-6 lg:mx-8 mt-6 overflow-hidden shadow-xl border-b-4 border-amber-400 min-h-[500px] flex items-center">
    <div class="absolute inset-0">
        {% if section.settings.image != blank %}
            <img
                src="{{ section.settings.image | image_url: width: 1600 }}"
                alt="{{ section.settings.title }}"
                class="w-full h-full object-cover"
            />
        {% else %}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'w-full h-full object-cover' }}
        {% endif %}
        <div class="absolute inset-0 bg-gradient-to-r from-emerald-950 via-emerald-900/80 to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-emerald-950/90 via-transparent to-transparent md:hidden"></div>
    </div>

    <div class="relative z-10 px-6 py-12 md:pl-20 flex flex-col items-start text-left max-w-4xl w-full">
        {% if section.settings.badge != blank %}
            <span class="inline-block py-1.5 px-4 bg-yellow-400 text-slate-900 text-xs font-bold uppercase tracking-wider mb-6 transform -skew-x-12 shadow-lg">
                {{ section.settings.badge }}
            </span>
        {% endif %}

        <h1 class="text-4xl md:text-7xl font-serif font-black tracking-tight mb-6 leading-tight text-white drop-shadow-md">
            {{ section.settings.title }}
        </h1>

        <p class="text-lg md:text-xl text-emerald-100 max-w-xl mb-10 leading-relaxed font-light drop-shadow-sm">
            {{ section.settings.text }}
        </p>

        <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
            {% if section.settings.button_link != blank %}
                <a href="{{ section.settings.button_link }}" class="bg-red-600 text-white font-bold py-4 px-8 rounded hover:bg-red-700 transition-all shadow-lg hover:shadow-xl transform hover:scale-105 flex items-center justify-center gap-2">
                    {{ section.settings.button_label }} <i data-lucide="arrow-right" class="w-5 h-5"></i>
                </a>
            {% endif %}
            {% if section.settings.secondary_button_link != blank %}
                <a href="{{ section.settings.secondary_button_link }}" class="bg-white/10 backdrop-blur-md border border-white/30 text-white font-bold py-4 px-8 rounded hover:bg-white/20 transition-all flex items-center justify-center gap-2">
                    {{ section.settings.secondary_button_label }}
                </a>
            {% endif %}
        </div>
    </div>
</div>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge Text",
      "default": "Great Value Prices"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Heading",
      "default": "<p>Authentic Flavours.<br /><span class='text-amber-400'>Local Convenience.</span></p>"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "The finest Indian groceries, sourced directly and delivered to your doorstep. From everyday staples to rare spices."
    },
    {
        "type": "text",
        "id": "button_label",
        "label": "Button Label",
        "default": "Shop Groceries"
    },
    {
        "type": "url",
        "id": "button_link",
        "label": "Button Link",
        "default": "/collections/all"
    },
    {
        "type": "text",
        "id": "secondary_button_label",
        "label": "Secondary Button Label",
        "default": "View Offers"
    },
    {
        "type": "url",
        "id": "secondary_button_link",
        "label": "Secondary Button Link"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
