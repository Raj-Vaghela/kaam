<header class="sticky top-0 z-40 bg-white shadow-md">
    <!-- Top Bar -->
    <div class="bg-emerald-900 text-emerald-50 text-xs py-2 px-4 border-b border-emerald-800">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <span class="flex items-center gap-2">
                <i data-lucide="truck" class="w-3 h-3 text-amber-400"></i> {{ section.settings.announcement_text | default: 'Next day delivery on orders placed by 8pm' }}
            </span>
            <div class="flex gap-4 font-medium">
                <a href="/pages/store-finder" class="cursor-pointer hover:text-white flex items-center gap-1">
                    <i data-lucide="map-pin" class="w-2.5 h-2.5"></i> Store Finder
                </a>
                <a href="/pages/contact" class="cursor-pointer hover:text-white flex items-center gap-1">
                    <i data-lucide="help-circle" class="w-2.5 h-2.5"></i> Help
                </a>
            </div>
        </div>
    </div>

    <!-- Main Header -->
    <div class="bg-white border-b border-slate-200">
        <div class="max-w-7xl mx-auto px-4 py-4 flex items-center gap-6">
            <!-- Logo -->
            <a href="{{ routes.root_url }}" class="flex-shrink-0 flex items-center gap-2 cursor-pointer">
                {% if section.settings.logo != blank %}
                    <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" class="h-10">
                {% else %}
                    <div class="bg-emerald-800 text-white p-2 rounded-sm">
                        <span class="font-serif font-black text-2xl leading-none block">{{ shop.name | slice: 0, 1 }}</span>
                    </div>
                    <div class="flex flex-col">
                        <h1 class="text-2xl font-serif font-black tracking-tight text-emerald-900 leading-none">DESI<span class="text-emerald-700">MART</span></h1>
                        <span class="text-[10px] tracking-widest text-slate-500 font-bold uppercase hidden md:block">Premier Grocery</span>
                    </div>
                {% endif %}
            </a>

            <!-- Search -->
            <form action="{{ routes.search_url }}" method="get" role="search" class="flex-grow relative max-w-3xl">
                <input
                    type="text"
                    name="q"
                    placeholder="Search products, brands and more..."
                    class="w-full pl-4 pr-12 py-3 rounded-lg border border-slate-300 focus:border-emerald-700 focus:ring-1 focus:ring-emerald-700 bg-slate-50 focus:bg-white transition-all text-sm"
                />
                <button type="submit" class="absolute right-0 top-0 h-full text-slate-400 hover:text-emerald-700 px-3 transition-colors">
                    <i data-lucide="search" class="w-5 h-5"></i>
                </button>
            </form>

            <!-- Icons -->
            <div class="hidden md:flex items-center gap-8 flex-shrink-0">
                {% if shop.customer_accounts_enabled %}
                    <a href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}" class="flex flex-col items-center cursor-pointer text-slate-700 hover:text-emerald-800 group">
                        <i data-lucide="user" class="w-6 h-6 stroke-[1.5]"></i>
                        <span class="text-[10px] font-bold mt-1">{% if customer %}Account{% else %}Sign In{% endif %}</span>
                    </a>
                {% endif %}
                
                <a href="{{ routes.cart_url }}" class="relative flex flex-col items-center cursor-pointer text-slate-700 hover:text-emerald-800 group" onclick="app.setCartOpen(true); return false;">
                    <div class="relative">
                        <i data-lucide="shopping-basket" class="w-6 h-6 stroke-[1.5]"></i>
                        {% if cart.item_count > 0 %}
                            <span id="cart-count-badge" class="absolute -top-1 -right-1 bg-red-600 text-white text-[9px] font-bold w-4 h-4 flex items-center justify-center rounded-full">{{ cart.item_count }}</span>
                        {% endif %}
                    </div>
                    <span id="cart-total-display" class="text-[10px] font-bold mt-1">{{ cart.total_price | money }}</span>
                </a>
            </div>
            <!-- Mobile Menu Details -->
            <button class="md:hidden p-2 text-slate-700">
                <i data-lucide="menu" class="w-6 h-6"></i>
            </button>
        </div>
    </div>

    <!-- Categories Nav -->
    <div class="bg-slate-100 border-b border-slate-200 py-1.5 overflow-x-auto scrollbar-hide">
        <div id="category-nav" class="max-w-7xl mx-auto px-4 flex items-center space-x-6">
            {% for link in linklists[section.settings.menu].links %}
                <a href="{{ link.url }}" class="text-xs font-bold whitespace-nowrap hover:text-emerald-700 text-slate-600 transition-colors">{{ link.title }}</a>
            {% endfor %}
        </div>
    </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement Text",
      "default": "Next day delivery on orders placed by 8pm"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
