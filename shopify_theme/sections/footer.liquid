<footer class="bg-slate-900 text-slate-300 pt-16 pb-8 border-t border-emerald-900">
    <div class="max-w-7xl mx-auto px-4">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8 mb-12 border-b border-slate-800 pb-12">
                <div>
                    <div class="flex items-center gap-2 mb-4">
                        <div class="bg-emerald-800 text-white p-1.5 rounded-sm">
                            <span class="font-serif font-black text-xl leading-none block">{{ shop.name | slice: 0, 1 }}</span>
                        </div>
                        <h2 class="text-2xl font-serif font-bold text-white tracking-tight">DESI<span class="text-emerald-500">MART</span></h2>
                    </div>
                    <p class="text-slate-400 text-sm max-w-md">Bringing the authentic taste of India to UK homes since 2010.</p>
                </div>
                <!-- Newsletter -->
                <div class="w-full md:w-auto bg-slate-800/50 p-6 rounded-lg border border-slate-700">
                    <h3 class="text-white font-bold mb-2">Join our newsletter</h3>
                    {% form 'customer' %}
                        <div class="flex gap-2">
                            <input type="hidden" name="contact[tags]" value="newsletter">
                            <input type="email" name="contact[email]" placeholder="Enter your email" class="bg-slate-900 border border-slate-700 text-white px-4 py-2 rounded text-sm w-full md:w-64" required>
                            <button type="submit" class="bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded text-sm font-bold">Subscribe</button>
                        </div>
                    {% endform %}
                </div>
            </div>
            <p class="text-center text-xs text-slate-500">&copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. All rights reserved.</p>
    </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}
