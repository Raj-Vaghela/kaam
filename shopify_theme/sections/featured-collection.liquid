<div class="max-w-7xl mx-auto px-4 py-8">
    <div class="mb-12">
        <div class="flex justify-between items-end mb-6 border-b border-slate-200 pb-2">
            <h2 class="text-3xl font-serif font-bold text-slate-900">{{ section.settings.title }}</h2>
            {% if section.settings.collection != blank %}
                <a href="{{ collections[section.settings.collection].url }}" class="text-emerald-700 font-bold hover:underline flex items-center gap-1 text-sm">
                    View All <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
                </a>
            {% endif %}
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-4">
            {%- assign collection = collections[section.settings.collection] -%}
            {% for product in collection.products limit: section.settings.limit %}
                <div class="flex flex-col bg-white border border-slate-300 hover:border-emerald-600 transition-all duration-200 rounded-lg overflow-hidden h-full shadow-sm hover:shadow-md group">
                    <div class="relative h-48 bg-white border-b border-slate-100 overflow-hidden">
                        <a href="{{ product.url }}">
                            <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                        </a>
                        <!-- Badges would go here -->
                    </div>
                    <div class="p-3 flex flex-col flex-grow">
                        <div class="mb-2">
                            <h3 class="text-slate-900 font-bold text-sm leading-snug min-h-[2.5rem] line-clamp-2 group-hover:text-emerald-800 transition-colors">
                                <a href="{{ product.url }}">{{ product.title }}</a>
                            </h3>
                            <!-- Unit display would require metafields or variant parsing -->
                        </div>
                        <div class="mt-auto">
                            <div class="mb-3 p-2 rounded">
                                <div class="flex items-baseline gap-2">
                                    <span class="text-xl font-bold text-slate-900">{{ product.price | money }}</span>
                                    {% if product.compare_at_price > product.price %}
                                        <span class="text-xs text-slate-400 line-through">{{ product.compare_at_price | money }}</span>
                                    {% endif %}
                                </div>
                            </div>
                           <form method="post" action="/cart/add">
                                <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
                                <button type="submit" class="w-full bg-emerald-800 hover:bg-emerald-900 text-white text-xs font-bold uppercase py-2 rounded transition-all flex items-center justify-center gap-1 active:scale-95 shadow-sm">
                                    Add <i data-lucide="shopping-basket" class="w-3 h-3"></i>
                                </button>
                           </form>
                        </div>
                    </div>
                </div>
            {% else %}
                {% for i in (1..5) %}
                    <div class="flex flex-col bg-white border border-slate-300 rounded-lg overflow-hidden h-full shadow-sm">
                        <div class="h-48 bg-slate-100 flex items-center justify-center">
                            {{ 'product-' | append: i | placeholder_svg_tag: 'w-full h-full object-cover opacity-50' }}
                        </div>
                        <div class="p-3">
                            <h3 class="font-bold text-slate-900 text-sm mb-2">Example Product {{ i }}</h3>
                            <div class="text-xl font-bold text-slate-900">£12.99</div>
                        </div>
                    </div>
                {% endfor %}
            {% endfor %}
        </div>
    </div>
</div>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Everyday Essentials"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 5,
      "label": "Products to show"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
