<div class="max-w-7xl mx-auto px-4 py-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-16">
        {% for block in section.blocks %}
            <div class="bg-white p-5 rounded border border-slate-200 flex items-center gap-5 shadow-sm hover:border-emerald-500 transition-all cursor-pointer group hover:shadow-md">
                <div class="bg-emerald-50 text-emerald-800 p-3 rounded-full group-hover:bg-emerald-800 group-hover:text-white transition-colors">
                    <i data-lucide="{{ block.settings.icon }}" class="w-6 h-6"></i>
                </div>
                <div>
                    <h3 class="font-serif font-bold text-slate-900 text-lg group-hover:text-emerald-800 transition-colors">{{ block.settings.title }}</h3>
                    <p class="text-slate-500 text-xs">{{ block.settings.text }}</p>
                </div>
            </div>
        {% endfor %}
    </div>
</div>

{% schema %}
{
  "name": "Features",
  "max_blocks": 3,
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Lucide Icon Name",
          "default": "clock",
          "info": "e.g., clock, shield-check, tag"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "Feature description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Service Features",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "clock",
            "title": "Next Day Delivery",
            "text": "Slots available from 8am tomorrow"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "shield-check",
            "title": "Authentic Quality",
            "text": "100% genuine imported brands"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "tag",
            "title": "Price Match",
            "text": "We match prices on 100+ items"
          }
        }
      ]
    }
  ]
}
{% endschema %}
