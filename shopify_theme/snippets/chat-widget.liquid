<div id="chat-widget">
    <!-- Button -->
    <button id="chat-toggle-btn" onclick="app.toggleChat(true)" class="fixed bottom-6 right-6 bg-slate-800 text-white p-3 rounded-full shadow-lg hover:bg-slate-700 z-40 flex items-center gap-2 pr-5">
        <div class="bg-emerald-500 rounded-full p-1.5">
            <i data-lucide="message-square" class="w-4 h-4 text-white"></i>
        </div>
        <span class="font-bold text-sm">Help & Support</span>
    </button>

    <!-- Chat Window -->
    <div id="chat-window" class="hidden fixed bottom-24 right-4 md:right-8 w-[90vw] md:w-80 bg-white rounded-t-lg shadow-2xl z-50 flex flex-col border border-slate-200 animate-slide-up h-[450px]">
        <div class="bg-slate-800 text-white p-3 rounded-t-lg flex justify-between items-center shadow-md">
            <div class="flex items-center gap-2">
                <i data-lucide="help-circle" class="w-4 h-4 text-white"></i>
                <h3 class="font-bold text-sm">Customer Support</h3>
            </div>
            <button onclick="app.toggleChat(false)" class="hover:bg-slate-700 p-1 rounded"><i data-lucide="x" class="w-4 h-4"></i></button>
        </div>
        
        <div id="chat-messages" class="flex-grow overflow-y-auto p-4 space-y-4 bg-slate-50 text-sm">
            <div class="flex justify-start">
                <div class="max-w-[85%] p-3 rounded-lg leading-relaxed shadow-sm bg-white text-slate-800 border border-slate-200">
                    Hello! I'm the DesiMart AI. I can help with navigation or basic queries.
                </div>
            </div>
        </div>

        <div class="px-4 py-2 bg-white border-t border-slate-100 flex gap-2 overflow-x-auto scrollbar-hide">
             <button onclick="app.handleChatSend('Where is my order?')" class="whitespace-nowrap px-3 py-1 bg-slate-100 text-slate-700 text-xs font-bold rounded hover:bg-slate-200">Track Order</button>
        </div>
        
        <div class="p-3 bg-white border-t border-slate-200">
            <div class="flex items-center gap-2 bg-slate-100 rounded px-3 py-2">
                <input type="text" id="chat-input" placeholder="Type a question..." class="flex-grow bg-transparent border-none text-sm focus:outline-none" onkeydown="if(event.key==='Enter') app.handleChatSend(this.value)">
                <button onclick="app.handleChatSend(document.getElementById('chat-input').value)" class="text-emerald-700 hover:text-emerald-900"><i data-lucide="send" class="w-4 h-4"></i></button>
            </div>
        </div>
    </div>
</div>
