<div id="trolley-overlay" class="fixed inset-0 z-50 flex justify-end hidden">
    <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm transition-opacity" onclick="app.setCartOpen(false)"></div>
    <div class="relative w-full max-w-md bg-white h-full shadow-2xl flex flex-col animate-slide-in-right">
        <div class="p-4 bg-emerald-900 text-white flex items-center justify-between shadow-md">
            <h2 class="text-lg font-bold flex items-center gap-2 font-serif">
               <i data-lucide="shopping-basket" class="w-6 h-6 text-amber-400"></i> Your Trolley
            </h2>
            <button onclick="app.setCartOpen(false)" class="p-2 hover:bg-white/10 rounded-full transition-colors"><i data-lucide="x" class="w-6 h-6"></i></button>
        </div>
        
        <div class="bg-slate-50 p-3 border-b border-slate-200">
            <div class="flex justify-between text-xs font-bold text-slate-700 mb-1">
                <span id="free-delivery-text">Spend £60.00 more for Free Delivery</span>
            </div>
            <div class="w-full bg-slate-200 rounded-full h-2">
                <div id="free-delivery-bar" class="bg-green-600 h-2 rounded-full transition-all duration-500" style="width: 0%"></div>
            </div>
        </div>

        <div id="cart-items-container" class="flex-grow overflow-y-auto p-4 bg-white space-y-3">
             <!-- Cart items injected here via JS or Liquid loop if static -->
             {% if cart.item_count == 0 %}
                <div class="text-center py-20 flex flex-col items-center">
                    <div class="bg-slate-50 p-6 rounded-full shadow-sm mb-4"><i data-lucide="shopping-basket" class="w-12 h-12 text-slate-300"></i></div>
                    <p class="text-lg font-bold text-slate-700 font-serif">Your trolley is empty</p>
                    <p class="text-sm text-slate-500 max-w-[200px] mb-6">Start adding your essentials.</p>
                </div>
             {% else %}
                {% for item in cart.items %}
                    <div class="bg-white p-2 border-b border-slate-100 flex gap-3 relative group">
                        <div class="w-16 h-16 bg-slate-50 border border-slate-200 rounded overflow-hidden">
                            <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title }}" class="w-full h-full object-cover" />
                        </div>
                        <div class="flex-grow">
                             <h3 class="font-bold text-slate-800 text-sm leading-tight line-clamp-2">{{ item.product.title }}</h3>
                             <p class="font-bold text-slate-900">{{ item.final_line_price | money }}</p>
                        </div>
                    </div>
                {% endfor %}
             {% endif %}
        </div>

        <div class="p-4 bg-slate-50 border-t border-slate-200">
             <div class="space-y-1 mb-4 text-sm">
                 <div class="flex justify-between text-slate-600"><span>Subtotal</span><span id="cart-subtotal">{{ cart.total_price | money }}</span></div>
                 <div class="flex justify-between text-xl font-bold text-slate-900 pt-3 border-t border-slate-200 mt-2 font-serif"><span>Total</span><span id="cart-total-footer">{{ cart.total_price | money }}</span></div>
             </div>
             <a href="/checkout" class="w-full bg-emerald-800 hover:bg-emerald-900 text-white font-bold py-3.5 rounded shadow-lg shadow-emerald-900/20 active:scale-95 flex items-center justify-center gap-2">
                 Checkout Securely <i data-lucide="arrow-right" class="w-4 h-4"></i>
             </a>
        </div>
    </div>
</div>
